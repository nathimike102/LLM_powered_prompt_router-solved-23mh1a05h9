# npm configuration
# More info: https://docs.npmjs.com/cli/v10/configuring-npm/npmrc

# Use lockfile version 3
lockfile-version=3

# Install exact versions from package-lock.json
save-exact=true

# Use semantic versioning for installs
save=true

# Audit level for security checks
audit-level=moderate

# Enable strict SSL by default (can be disabled per-auth if needed)
strict-ssl=true

# Install scripts enabled
ignore-scripts=false

# Prefer offline mode if possible
prefer-offline=true

# Use legacy peer deps resolution (uncomment if needed for compatibility)
# legacy-peer-deps=true
